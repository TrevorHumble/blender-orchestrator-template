# Python bytecode (Blender/CPython byte-compile imported eval/test modules)
__pycache__/
*.pyc

# Visual-confirmation previews — generated by tools/render_preview.py.
# Not committed: each render is falsified by the next geometry change (same
# reasoning as the no-FINAL-in-filenames rule). They live as downloadable CI
# artifacts (the "addon-previews" upload), not as repo files.
renders/

# Personal Claude Code overrides — never commit (may hold machine-specific paths/keys).
.claude/settings.local.json

# Secrets — never commit.
.env
*.env

# Ephemeral local gate state (each dir also self-ignores, belt-and-suspenders).
.review_state/
.run_state/
